<test>
import { describe, it, expect } from 'vitest'
import { render } from '@matthesketh/utopia-test'

describe('ProjectCard', () => {
  it('renders project name and description', () => {
    const { getByText, unmount } = render(self, {
      props: {
        name: 'UtopiaJS',
        description: 'Compiler-first UI framework',
        details: ['18k lines of TypeScript'],
        url: 'https://github.com/wrxck/utopiajs',
      }
    })
    expect(getByText('UtopiaJS')).toBeTruthy()
    unmount()
  })
})
</test>
