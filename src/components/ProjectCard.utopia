<template>
  <div class="project-card">
    <div class="project-header">
      <span class="project-name">{{ name }}</span>
      <span class="project-desc">— {{ description }}</span>
    </div>
    <ul class="project-details">
      <li u-for="detail in details">{{ detail }}</li>
    </ul>
    <a u-if="url" :href="url" class="project-link" target="_blank" rel="noopener noreferrer">
      {{ url }}
    </a>
  </div>
</template>

<script>
export let name = ''
export let description = ''
export let details: string[] = []
export let url = ''
</script>

<style scoped>
.project-card {
  border-left: 2px solid #f0f;
  padding: 0.75rem 1rem;
}

