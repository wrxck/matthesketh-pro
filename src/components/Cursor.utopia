<template>
  <span class="cursor">_</span>
</template>

<script>
</script>

<style scoped>
.cursor {
  display: inline-block;
  color: #0ff;
  animation: blink 1s step-end infinite;
  font-weight: 700;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

@media print {
  .cursor { display: none; }
}
</style>

<test>
import { describe, it, expect } from 'vitest'
import { render } from '@matthesketh/utopia-test'

describe('Cursor', () => {
  it('renders blinking cursor character', () => {
    const { getBySelector, unmount } = render(self)
    const cursor = getBySelector('.cursor')
    expect(cursor).toBeTruthy()
    expect(cursor!.textContent).toBe('_')
    unmount()
  })
})
</test>
